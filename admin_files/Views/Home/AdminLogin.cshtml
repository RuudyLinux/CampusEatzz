@{
    Layout = null;
    ViewData["Title"] = "Admin Login - CampusEatzz";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="../CSS/style.css?v=20260505a">
</head>
<body class="min-h-screen flex items-center justify-center p-4 flex-col">
    <div class="w-full max-w-md">
        <!-- Login Card -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden" style="border:1px solid var(--surface-border)">
            <!-- Header -->
            <div class="gradient-bg p-8 text-center">
                <div class="flex justify-center mb-4">
                    <img src="@Url.Content("~/assets/img/logo.png?v=2")" alt="CampusEatzz"
                         class="app-logo h-20 w-20 rounded-full object-cover ring-2 ring-white/50 shadow-lg"
                         onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2280%22 height=%2280%22%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22%233c3c78%22/%3E%3Ctext x=%2250%25%22 y=%2256%25%22 text-anchor=%22middle%22 fill=%22%23fff%22 font-size=%2222%22 font-family=%22Segoe UI,Arial,sans-serif%22%3ECE%3C/text%3E%3C/svg%3E'">
                </div>
                <h1 class="app-name text-3xl font-bold text-white mb-1">CampusEatzz</h1>
                <p class="text-white/70 text-sm">Admin portal — manage the platform</p>
            </div>

            <!-- Form -->
            <div class="p-8">
                <div id="error-message" class="border-l-4 p-4 mb-6 rounded-lg items-start hidden" style="background:var(--surface-low);border-color:var(--danger)">
                    <i class="fas fa-exclamation-circle mt-0.5 mr-3" style="color:var(--danger)"></i>
                    <span id="error-text" style="color:var(--danger)"></span>
                </div>

                <form id="admin-login-form" novalidate>
                    <!-- Email Field -->
                    <div class="mb-5">
                        <label for="email" class="block text-sm font-semibold mb-2" style="color:var(--text-strong)">
                            Email Address
                        </label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-3 top-3.5" style="color:var(--text-muted)"></i>
                            <input type="email" id="email" name="email" required
                                   class="w-full pl-10 pr-4 py-2.5 transition"
                                   placeholder="Enter your email">
                        </div>
                    </div>

                    <!-- Password Field -->
                    <div class="mb-2">
                        <label for="password" class="block text-sm font-semibold mb-2" style="color:var(--text-strong)">
                            Password
                        </label>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-3 top-3.5" style="color:var(--text-muted)"></i>
                            <input type="password" id="password" name="password" required
                                   class="w-full pl-10 pr-10 py-2.5 transition"
                                   placeholder="Enter your password">
                            <button type="button" id="togglePassword"
                                    class="absolute right-3 top-3 p-0.5 rounded transition"
                                    onclick="document.getElementById('password').type = document.getElementById('password').type === 'password' ? 'text' : 'password'; this.querySelector('i').classList.toggle('fa-eye'); this.querySelector('i').classList.toggle('fa-eye-slash');"
                                    aria-label="Toggle password visibility">
                                <i class="fas fa-eye text-sm" style="color:var(--text-muted)"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Remember & Forgot -->
                    <div class="flex items-center justify-between mb-6 mt-4">
                        <label class="flex items-center gap-2 cursor-pointer select-none">
                            <input type="checkbox" name="remember" class="w-4 h-4 rounded accent-primary" style="accent-color:var(--primary)">
                            <span class="text-sm" style="color:var(--text-muted)">Remember me</span>
                        </label>
                        <a href="#" class="text-sm font-medium hover:underline" style="color:var(--primary)">Forgot password?</a>
                    </div>

                    <!-- Login Button -->
                    <button type="submit" id="login-btn"
                            class="w-full bg-blue-600 text-white font-bold py-3 px-4 rounded-xl flex items-center justify-center gap-2 transition">
                        <i class="fas fa-right-to-bracket" id="login-icon"></i>
                        <span id="login-text">Sign In</span>
                    </button>
                </form>
            </div>
        </div>

        <p class="text-center text-xs mt-4" style="color:var(--text-muted)">&copy; @DateTime.Now.Year CampusEatzz. Admin access only.</p>
    </div>

    <partial name="_AdminFooter" />

    <script>
        window.__API_BASE = "@(ViewBag.ApiBaseUrl ?? "https://campuseatzz.onrender.com")";
    </script>
    <script src="../JS/admin-common.js?v=20260427a"></script>
    <script src="../JS/admin-login.js?v=20260427a"></script>
</body>
</html>
