@{
    Layout = null;
    ViewData["Title"] = "Platform Settings - CampusEatzz";
    ViewData["AdminActivePage"] = "Settings";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="../CSS/style.css">
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
        <partial name="_AdminTopNav" />

    <section class="gradient-bg text-white py-10">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-4xl font-bold mb-2">Platform Settings</h1>
            <p class="text-blue-200">Manage app branding, pricing, profile, and maintenance controls.</p>
        </div>
    </section>

    <div class="container mx-auto px-6 py-10 -mt-6 space-y-6">
        <div id="message-container" class="fixed top-4 right-4 z-50"></div>

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <div class="xl:col-span-2 space-y-6">
                <div class="bg-white rounded-lg shadow-lg p-6">
                    <h2 class="text-xl font-bold text-gray-800 mb-4">Application Configuration</h2>
                    <form id="settings-form" class="space-y-4">
                        <div>
                            <label for="setting-app_name" class="block text-sm font-medium text-gray-700 mb-1">Application Name</label>
                            <input id="setting-app_name" type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="CampusEatzz" required>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="setting-tax_percentage" class="block text-sm font-medium text-gray-700 mb-1">Tax Percentage (%)</label>
                                <input id="setting-tax_percentage" type="number" min="0" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                            </div>
                            <div>
                                <label for="setting-delivery_charge" class="block text-sm font-medium text-gray-700 mb-1">Delivery Charge</label>
                                <input id="setting-delivery_charge" type="number" min="0" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                            </div>
                            <div>
                                <label for="setting-min_order_delivery" class="block text-sm font-medium text-gray-700 mb-1">Minimum Delivery Order</label>
                                <input id="setting-min_order_delivery" type="number" min="0" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                            </div>
                            <div>
                                <label for="setting-operating_hours_open" class="block text-sm font-medium text-gray-700 mb-1">Opening Time</label>
                                <input id="setting-operating_hours_open" type="time" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                            </div>
                            <div>
                                <label for="setting-operating_hours_close" class="block text-sm font-medium text-gray-700 mb-1">Closing Time</label>
                                <input id="setting-operating_hours_close" type="time" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Application Logo</label>
                            <div class="flex items-center gap-4 flex-wrap">
                                <img id="logo-preview" src="@Url.Content("~/assets/img/logo.png?v=2")" alt="App logo preview" class="app-logo h-16 w-16 rounded-full border border-gray-300 object-cover">
                                <div class="flex-1 min-w-[220px]">
                                    <input id="logo-file" type="file" accept=".jpg,.jpeg,.png,.webp,.svg" class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg p-2">
                                    <p class="text-xs text-gray-500 mt-1">Allowed: JPG, PNG, WebP, SVG. Max size: 5 MB.</p>
                                </div>
                            </div>
                        </div>

                        <div class="flex justify-end">
                            <button id="save-settings-btn" type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                                <i class="fas fa-save mr-2"></i>Save App Settings
                            </button>
                        </div>
                    </form>
                </div>

                <div class="bg-white rounded-lg shadow-lg p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <h2 class="text-xl font-bold text-gray-800">System-wide Maintenance Mode</h2>
                            <p class="text-sm text-gray-600 mt-1">Enable maintenance for all canteens.</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="system-maintenance-toggle" class="sr-only peer">
                            <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-blue-600"></div>
                        </label>
                    </div>
                    <div>
                        <label for="system-reason-text" class="block text-sm font-medium text-gray-700 mb-1">Maintenance Reason</label>
                        <textarea id="system-reason-text" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg" placeholder="Enter reason for maintenance..."></textarea>
                        <div class="mt-3 flex gap-3">
                            <button id="save-system-maintenance-btn" type="button" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">Save</button>
                            <button id="reload-maintenance-btn" type="button" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors">Reload</button>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow-lg">
                    <div class="p-6 border-b border-gray-200">
                        <h2 class="text-xl font-bold text-gray-800">Canteen Maintenance Mode</h2>
                        <p class="text-sm text-gray-600 mt-1">Enable or disable maintenance for specific canteens.</p>
                    </div>
                    <div id="canteens-container" class="divide-y divide-gray-200"></div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-white rounded-lg shadow-lg p-6">
                    <h2 class="text-xl font-bold text-gray-800 mb-4">Admin Profile</h2>
                    <form id="profile-form" class="space-y-4">
                        <div>
                            <label for="profile-name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                            <input id="profile-name" type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                        </div>
                        <div>
                            <label for="profile-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                            <input id="profile-email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                        </div>
                        <button id="save-profile-btn" type="submit" class="w-full bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">Update Profile</button>
                    </form>
                </div>

                <div class="bg-white rounded-lg shadow-lg p-6">
                    <h2 class="text-xl font-bold text-gray-800 mb-4">Change Password</h2>
                    <form id="password-form" class="space-y-4">
                        <div>
                            <label for="current-password" class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
                            <input id="current-password" type="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                        </div>
                        <div>
                            <label for="new-password" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
                            <input id="new-password" type="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg" minlength="6" required>
                        </div>
                        <div>
                            <label for="confirm-password" class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
                            <input id="confirm-password" type="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg" minlength="6" required>
                        </div>
                        <button id="save-password-btn" type="submit" class="w-full bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition-colors">Change Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <partial name="_AdminFooter" />

    <script src="../JS/admin-common.js"></script>
    <script src="../JS/admin-settings.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
