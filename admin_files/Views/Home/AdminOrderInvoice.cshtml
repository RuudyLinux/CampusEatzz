@{
    Layout = null;
    ViewData["Title"] = "Order Invoice - CampusEatzz";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="../CSS/style.css?v=20260505a">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <style>
        @@media print {
            .no-print { display: none; }
            body { background: white; }
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col">
    <div class="container mx-auto px-6 py-10">
        <div class="bg-white rounded-lg shadow-lg p-8 max-w-4xl mx-auto">
            <!-- Header -->
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">INVOICE</h1>
                    <p class="text-gray-600">Order #<span id="orderId"></span></p>
                    <p class="text-gray-600">Date: <span id="orderDate"></span></p>
                </div>
                <div class="text-right">
                    <h2 class="text-xl font-bold text-purple-600">Campus Café</h2>
                    <p class="text-sm text-gray-600">CampusEatzz Ordering System</p>
                </div>
            </div>

            <!-- Customer & Canteen Details -->
            <div class="grid grid-cols-2 gap-8 mb-8">
                <div>
                    <h3 class="font-semibold text-gray-700 mb-2">Bill To:</h3>
                    <p id="customerName" class="text-gray-900"></p>
                    <p id="customerPhone" class="text-gray-600"></p>
                    <p id="customerEmail" class="text-gray-600"></p>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-700 mb-2">From:</h3>
                    <p id="canteenName" class="text-gray-900"></p>
                    <p class="text-gray-600">Campus Canteen</p>
                </div>
            </div>

            <!-- Order Items -->
            <div class="mb-8">
                <table class="w-full">
                    <thead class="bg-purple-100">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Item</th>
                            <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700">Qty</th>
                            <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Price</th>
                            <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Total</th>
                        </tr>
                    </thead>
                    <tbody id="itemsTable" class="divide-y divide-gray-200">
                        <!-- Items will be loaded here -->
                    </tbody>
                </table>
            </div>

            <!-- Totals -->
            <div class="flex justify-end mb-8">
                <div class="w-64">
                    <div class="flex justify-between py-2 text-gray-700">
                        <span>Subtotal:</span>
                        <span id="subtotal">₹0.00</span>
                    </div>
                    <div class="flex justify-between py-2 text-gray-700">
                        <span>Tax (0%):</span>
                        <span id="tax">₹0.00</span>
                    </div>
                    <div class="flex justify-between py-3 border-t-2 border-gray-300 font-bold text-lg text-purple-600">
                        <span>Total:</span>
                        <span id="total">₹0.00</span>
                    </div>
                </div>
            </div>

            <!-- Payment & Status Info -->
            <div class="grid grid-cols-2 gap-8 mb-8 p-4 bg-gray-50 rounded">
                <div>
                    <p class="text-sm text-gray-600">Payment Method</p>
                    <p id="paymentMethod" class="font-semibold text-gray-900"></p>
                </div>
                <div>
                    <p class="text-sm text-gray-600">Order Status</p>
                    <p id="orderStatus" class="font-semibold"></p>
                </div>
            </div>

            <!-- Special Instructions -->
            <div id="specialInstructionsDiv" class="hidden mb-8 p-4 bg-yellow-50 rounded">
                <p class="text-sm text-gray-700 font-semibold mb-1">Special Instructions:</p>
                <p id="specialInstructions" class="text-gray-900"></p>
            </div>

            <!-- Footer Note -->
            <div class="text-center text-sm text-gray-600 mb-6">
                <p>Thank you for your order!</p>
                <p>For any queries, please contact our support team.</p>
            </div>

            <!-- Action Buttons -->
            <div class="flex gap-4 no-print">
                <button onclick="window.print()" class="flex-1 bg-purple-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-purple-700 transition">
                    <i class="fas fa-print mr-2"></i>Print Invoice
                </button>
                <button onclick="goBack()" class="flex-1 bg-gray-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gray-700 transition">
                    <i class="fas fa-arrow-left mr-2"></i>Go Back
                </button>
            </div>
        </div>
    </div>

    
    <partial name="_AdminFooter" />

    <script src="../JS/admin-common.js"></script>
    <script src="../JS/admin-order-invoice.js"></script>
</body>
</html>
