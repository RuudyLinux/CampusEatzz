@{
    Layout = null;
    ViewData["Title"] = "Manage Canteens - CampusEatzz";
    ViewData["AdminActivePage"] = "Canteens";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="../CSS/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
        <partial name="_AdminTopNav" />

    <section class="gradient-bg text-white py-12">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-4xl font-bold mb-2">Manage Canteens</h1>
            <p class="text-white/70">Add, edit and manage all canteens across campus</p>
        </div>
    </section>

    <div class="container mx-auto px-6 py-10 -mt-8">
        <div id="message" class="hidden mb-4 p-4 rounded-lg"></div>

        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-gray-800">All Canteens (<span id="canteenCount">0</span>)</h2>
            <button onclick="openAddModal()" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                <i class="fas fa-plus mr-2"></i>Add New Canteen
            </button>
        </div>

        <div id="canteenGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Canteens will be loaded here -->
        </div>

        <div id="loadingIndicator" class="text-center py-8">
            <i class="fas fa-spinner fa-spin text-4xl text-blue-600"></i>
            <p class="mt-3 text-gray-600">Loading canteens...</p>
        </div>
    </div>

    <!-- Add/Edit Modal -->
    <div id="canteenModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-8 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <h3 id="modalTitle" class="text-2xl font-bold text-gray-800 mb-6">Add New Canteen</h3>
            <form id="canteenForm">
                <input type="hidden" id="canteenId">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Canteen Name *</label>
                    <input type="text" id="canteenName" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500">
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Description</label>
                    <textarea id="canteenDescription" rows="3"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"></textarea>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Image URL</label>
                    <input type="url" id="canteenImageUrl" placeholder="https://example.com/canteen-image.jpg"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500">
                    <p class="text-xs text-gray-500 mt-2">Paste an image link to set or change canteen image.</p>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Or Upload Image</label>
                    <input type="file" id="canteenImageFile" accept=".jpg,.jpeg,.png,.webp,image/*"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:border-blue-500">
                    <p id="canteenImageFileLabel" class="text-xs text-gray-500 mt-2">No file chosen.</p>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Preview</label>
                    <div class="w-full h-40 rounded-lg border border-gray-200 bg-gray-100 overflow-hidden">
                        <img id="canteenImagePreview" alt="Canteen image preview" class="w-full h-full object-cover" />
                    </div>
                </div>
                <div class="mb-6">
                    <label class="flex items-center">
                        <input type="checkbox" id="canteenActive" checked
                               class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                        <span class="ml-2 text-gray-700 font-semibold">Active</span>
                    </label>
                </div>
                <div class="flex gap-4">
                    <button type="submit" class="flex-1 bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                        <i class="fas fa-save mr-2"></i>Save Canteen
                    </button>
                    <button type="button" onclick="closeModal()" class="flex-1 bg-gray-300 text-gray-700 py-3 rounded-lg font-semibold hover:bg-gray-400 transition">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>

    <partial name="_AdminFooter" />

    <script src="../JS/admin-common.js?v=20260427b"></script>
    <script src="../JS/admin-manage-canteens.js?v=20260427b"></script>
</body>
</html>
