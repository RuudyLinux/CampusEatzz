@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard - CampusEatzz";
    ViewData["AdminActivePage"] = "Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="../CSS/style.css">
</head>
<body class="min-h-screen flex flex-col">

    <partial name="_AdminTopNav" />

    <!-- Hero Section -->
    <section class="gradient-bg text-white py-10">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-4xl font-bold mb-1">Admin Dashboard</h1>
            <p class="text-white/70 text-sm">Platform overview &amp; management</p>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="container mx-auto px-6 py-8 -mt-6 relative z-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 xl:gap-6">

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-pink-100">
                    <i class="fas fa-shopping-bag text-xl text-pink-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Total Orders</p>
                    <h3 id="stat-totalOrders" class="text-2xl font-bold" style="color:var(--primary)">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-orange-100">
                    <i class="fas fa-clock text-xl text-orange-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Pending</p>
                    <h3 id="stat-pendingOrders" class="text-2xl font-bold text-orange-600">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-green-100">
                    <i class="fas fa-calendar-day text-xl text-green-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Today</p>
                    <h3 id="stat-todayOrders" class="text-2xl font-bold text-green-600">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-purple-100">
                    <i class="fas fa-indian-rupee-sign text-xl text-purple-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Revenue</p>
                    <h3 id="stat-totalRevenue" class="text-2xl font-bold text-purple-600">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-indigo-100">
                    <i class="fas fa-users text-xl text-indigo-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Users</p>
                    <h3 id="stat-totalUsers" class="text-2xl font-bold text-indigo-600">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-green-100">
                    <i class="fas fa-check-circle text-xl text-green-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Completed</p>
                    <h3 id="stat-completedOrders" class="text-2xl font-bold text-green-600">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-red-100">
                    <i class="fas fa-times-circle text-xl text-red-600"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Cancelled</p>
                    <h3 id="stat-cancelledOrders" class="text-2xl font-bold text-red-600">—</h3>
                </div>
            </div>

            <div class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 transition-all">
                <div class="rounded-full p-3 shrink-0 bg-pink-100">
                    <i class="fas fa-envelope text-xl" style="color:var(--primary)"></i>
                </div>
                <div>
                    <p class="text-xs uppercase font-medium tracking-wide" style="color:var(--text-muted)">Unread</p>
                    <h3 id="stat-unreadMessages" class="text-2xl font-bold" style="color:var(--primary)">—</h3>
                </div>
            </div>

        </div>
    </section>

    <!-- Quick Actions -->
    <section class="container mx-auto px-6 pb-10">
        <h2 class="text-xl font-bold mb-4" style="color:var(--text-strong)">Quick Actions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <a href='@Url.Action("AdminAllOrders","Home")'
               class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 hover:no-underline transition-all group">
                <div class="rounded-full p-3 bg-pink-100 group-hover:bg-pink-200 transition shrink-0">
                    <i class="fas fa-shopping-bag text-xl" style="color:var(--primary)"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold" style="color:var(--text-strong)">All Orders</h3>
                    <p class="text-sm" style="color:var(--text-muted)">View and manage campus orders</p>
                </div>
                <i class="fas fa-chevron-right text-sm shrink-0" style="color:var(--text-muted)"></i>
            </a>

            <a href='@Url.Action("AdminManageCanteens","Home")'
               class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 hover:no-underline transition-all group">
                <div class="rounded-full p-3 bg-green-100 group-hover:bg-green-200 transition shrink-0">
                    <i class="fas fa-store text-xl text-green-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold" style="color:var(--text-strong)">Canteens</h3>
                    <p class="text-sm" style="color:var(--text-muted)">Manage all campus canteens</p>
                </div>
                <i class="fas fa-chevron-right text-sm shrink-0" style="color:var(--text-muted)"></i>
            </a>

            <a href='@Url.Action("AdminReports","Home")'
               class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 hover:no-underline transition-all group">
                <div class="rounded-full p-3 bg-purple-100 group-hover:bg-purple-200 transition shrink-0">
                    <i class="fas fa-chart-bar text-xl text-purple-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold" style="color:var(--text-strong)">Reports</h3>
                    <p class="text-sm" style="color:var(--text-muted)">Analytics &amp; business insights</p>
                </div>
                <i class="fas fa-chevron-right text-sm shrink-0" style="color:var(--text-muted)"></i>
            </a>

            <a href='@Url.Action("AdminManageUsers","Home")'
               class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 hover:no-underline transition-all group">
                <div class="rounded-full p-3 bg-orange-100 group-hover:bg-orange-200 transition shrink-0">
                    <i class="fas fa-users text-xl text-orange-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold" style="color:var(--text-strong)">Users</h3>
                    <p class="text-sm" style="color:var(--text-muted)">Manage customer accounts</p>
                </div>
                <i class="fas fa-chevron-right text-sm shrink-0" style="color:var(--text-muted)"></i>
            </a>

            <a href='@Url.Action("AdminSettings","Home")'
               class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 hover:no-underline transition-all group">
                <div class="rounded-full p-3 bg-indigo-100 group-hover:bg-indigo-200 transition shrink-0">
                    <i class="fas fa-gear text-xl text-indigo-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold" style="color:var(--text-strong)">Settings</h3>
                    <p class="text-sm" style="color:var(--text-muted)">Platform configuration</p>
                </div>
                <i class="fas fa-chevron-right text-sm shrink-0" style="color:var(--text-muted)"></i>
            </a>

            <a href='@Url.Action("AdminWallets","Home")'
               class="stat-card bg-white rounded-xl p-5 flex items-center gap-4 hover:no-underline transition-all group">
                <div class="rounded-full p-3 bg-teal-100 group-hover:bg-teal-200 transition shrink-0">
                    <i class="fas fa-wallet text-xl text-teal-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold" style="color:var(--text-strong)">Wallets</h3>
                    <p class="text-sm" style="color:var(--text-muted)">Monitor wallet transactions</p>
                </div>
                <i class="fas fa-chevron-right text-sm shrink-0" style="color:var(--text-muted)"></i>
            </a>

        </div>
    </section>

    <partial name="_AdminFooter" />

    <script src="../JS/admin-common.js?v=20260427a"></script>
    <script src="../JS/admin-dashboard.js?v=20260427a"></script>
</body>
</html>
