@{
    Layout = null;
    ViewData["Title"] = "Sales Reports - CampusEatzz";
    ViewData["AdminActivePage"] = "Reports";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="../CSS/style.css">
    <style>
        @@media print {
            body * { visibility: hidden; }
            #print-section, #print-section * { visibility: visible; }
            #print-section { position: absolute; left: 0; top: 0; width: 100%; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
        <partial name="_AdminTopNav" />

    <section class="gradient-bg text-white py-12 no-print">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-4xl font-bold mb-2">Sales Reports</h1>
            <p class="text-white/70">Analytics and business insights</p>
        </div>
    </section>

    <div class="container mx-auto px-6 py-10 -mt-8">
            <!-- Period Selection -->
            <div class="bg-white rounded-lg shadow-lg p-6 mb-6 no-print">
                <h2 class="text-xl font-bold mb-4 text-gray-800">Select Report Period</h2>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <button onclick="selectPeriod('daily')" id="btn-daily" class="px-4 py-2 border-2 border-blue-600 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                        <i class="fas fa-calendar-day mr-2"></i>Daily
                    </button>
                    <button onclick="selectPeriod('weekly')" id="btn-weekly" class="px-4 py-2 border-2 border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                        <i class="fas fa-calendar-week mr-2"></i>Weekly
                    </button>
                    <button onclick="selectPeriod('monthly')" id="btn-monthly" class="px-4 py-2 border-2 border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                        <i class="fas fa-calendar-alt mr-2"></i>Monthly
                    </button>
                    <button onclick="selectPeriod('custom')" id="btn-custom" class="px-4 py-2 border-2 border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                        <i class="fas fa-calendar-check mr-2"></i>Custom
                    </button>
                </div>
                <div id="custom-date-range" class="mt-4 hidden">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
                            <input type="date" id="start-date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">End Date</label>
                            <input type="date" id="end-date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                        </div>
                    </div>
                    <button onclick="generateReport()" class="mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                        <i class="fas fa-search mr-2"></i>Generate Report
                    </button>
                </div>
            </div>

            <div id="print-section">
                <!-- Overall Statistics -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white rounded-lg shadow p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Total Orders</p>
                                <p id="total-orders" class="text-3xl font-bold text-gray-800">0</p>
                            </div>
                            <div class="bg-blue-100 p-4 rounded-full">
                                <i class="fas fa-shopping-bag text-blue-600 text-2xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Total Revenue</p>
                                <p id="total-revenue" class="text-3xl font-bold text-green-600">₹0</p>
                            </div>
                            <div class="bg-green-100 p-4 rounded-full">
                                <i class="fas fa-rupee-sign text-green-600 text-2xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Total Tax</p>
                                <p id="total-tax" class="text-3xl font-bold text-orange-600">₹0</p>
                            </div>
                            <div class="bg-orange-100 p-4 rounded-full">
                                <i class="fas fa-percentage text-orange-600 text-2xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Avg Order Value</p>
                                <p id="avg-order-value" class="text-3xl font-bold text-purple-600">₹0</p>
                            </div>
                            <div class="bg-purple-100 p-4 rounded-full">
                                <i class="fas fa-chart-line text-purple-600 text-2xl"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Canteen-wise Sales -->
                <div class="bg-white rounded-lg shadow-lg mb-6">
                    <div class="p-6 border-b border-gray-200 flex justify-between items-center">
                        <h2 class="text-xl font-bold text-gray-800">Canteen-wise Sales Breakdown</h2>
                        <button onclick="window.print()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors no-print">
                            <i class="fas fa-print mr-2"></i>Print Report
                        </button>
                    </div>
                    <div class="p-6">
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Canteen</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Orders</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Revenue</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Avg Order</th>
                                    </tr>
                                </thead>
                                <tbody id="canteen-sales-body" class="bg-white divide-y divide-gray-200">
                                    <!-- Canteen sales will be loaded here -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Payment Method Breakdown -->
                <div class="bg-white rounded-lg shadow-lg">
                    <div class="p-6 border-b border-gray-200">
                        <h2 class="text-xl font-bold text-gray-800">Payment Method Breakdown</h2>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="bg-blue-50 p-4 rounded-lg">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-gray-700 font-medium">Wallet</span>
                                    <i class="fas fa-wallet text-blue-600"></i>
                                </div>
                                <p id="wallet-count" class="text-2xl font-bold text-blue-600">0</p>
                                <p id="wallet-revenue" class="text-sm text-gray-600">₹0.00</p>
                            </div>
                            <div class="bg-purple-50 p-4 rounded-lg">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-gray-700 font-medium">UPI</span>
                                    <i class="fas fa-mobile-alt text-purple-600"></i>
                                </div>
                                <p id="upi-count" class="text-2xl font-bold text-purple-600">0</p>
                                <p id="upi-revenue" class="text-sm text-gray-600">₹0.00</p>
                            </div>
                            <div class="bg-green-50 p-4 rounded-lg">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-gray-700 font-medium">Cash</span>
                                    <i class="fas fa-money-bill text-green-600"></i>
                                </div>
                                <p id="cash-count" class="text-2xl font-bold text-green-600">0</p>
                                <p id="cash-revenue" class="text-sm text-gray-600">₹0.00</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    </div>

    
    <partial name="_AdminFooter" />

    <script src="../JS/admin-common.js"></script>
    <script src="../JS/admin-reports.js"></script>
</body>
</html>
