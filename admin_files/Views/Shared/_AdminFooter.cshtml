@inject IConfiguration Configuration
@{
    var configuredApiBase = Configuration["Frontend:ApiBaseUrl"];
    var apiBase = string.IsNullOrWhiteSpace(configuredApiBase)
        ? string.Empty
        : System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(configuredApiBase.Trim());
}

<footer class="admin-footer text-white py-8 mt-auto gradient-bg">
    <div class="container mx-auto px-6 text-center">
        <p class="text-sm font-medium">&copy; @DateTime.Now.Year <span class="app-name">CampusEatzz</span>. All rights reserved.</p>
    </div>
</footer>

@if (!string.IsNullOrWhiteSpace(apiBase))
{
    <script>
        window.__API_BASE = "@apiBase";
        window.__API_BASE_CANDIDATES = ["@apiBase"];
    </script>
}
